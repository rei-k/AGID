    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "שם הבניין/חברה", "placeholder": "מגדל עזריאלי", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "מספר בית", "placeholder": "1", "required": true, "type": "text" },
      { "key": "street", "label": "רחוב", "placeholder": "דרך מנחם בגין", "required": true, "type": "text" },
      { "key": "city", "label": "עיר", "placeholder": "תל אביב", "required": true, "type": "text" },
      { "key": "postcode", "label": "מיקוד", "placeholder": "6701101", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{city}}\n{{postcode}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Building/Company", "placeholder": "Azrieli Tower", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "House No.", "placeholder": "1", "required": true, "type": "text" },
