      { "key": "city", "label": "City", "placeholder": "Tel Aviv", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "6701101", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNNNN",
    "regex": "^\\d{7}$",
    "api": "https://israelpost.co.il/%D7%A9%D7%99%D7%A8%D7%95%D7%AA%D7%99%D7%9D/%D7%90%D7%99%D7%AA%D7%95%D7%A8-%D7%9e%D7%99%D7%A7%D7%95%D7%93/",
    "source": "Israel Post"
  }
