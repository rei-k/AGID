      { "key": "street", "label": "Straße", "placeholder": "Hauptstraße", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Hausnummer", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postleitzahl", "placeholder": "10115", "required": true, "type": "text" },
      { "key": "city", "label": "Stadt", "placeholder": "Berlin", "required": true, "type": "text" }
    ]
  },
  "english": {
    "name": "International English",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{postcode}} {{city}}\nGERMANY",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Co./Org.", "placeholder": "" },
      { "key": "houseNumber", "label": "No.", "placeholder": "1" },
      { "key": "street", "label": "Street (Latin)", "placeholder": "Hauptstrasse" },
      { "key": "postcode", "label": "Postcode", "placeholder": "10115" },
      { "key": "city", "label": "City", "placeholder": "Berlin" }
