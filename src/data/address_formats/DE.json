        { "key": "postcode", "label": "PLZ", "placeholder": "10115" },
        { "key": "city", "label": "Stadt", "placeholder": "Berlin" }
      ]
    }
  },
  "postalCode": {
    "format": "NNNNN",
    "regex": "^\\d{5}$",
