{
  "countryCode": "LU",
  "name": "Luxembourg",
  "native": {
    "name": "Lëtzebuerg",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Firma / Société", "placeholder": "", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "Nummer / Numéro", "placeholder": "1", "required": true, "type": "text" },
      { "key": "street", "label": "Strooss / Rue", "placeholder": "Boulevard Royal", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postcode / Code Postal", "placeholder": "2449", "required": true, "type": "text" },
      { "key": "city", "label": "Stad / Ville", "placeholder": "Lëtzebuerg", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{postcode}} {{city}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company/Organization", "placeholder": "", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "House No.", "placeholder": "1", "required": true, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Boulevard Royal", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "2449", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Luxembourg", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNN",
    "regex": "^\\d{4}$",
    "api": "https://www.post.lu/particuliers/courrier/recherche-code-postal",
    "source": "POST Luxembourg"
  }
}
