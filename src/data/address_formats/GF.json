      { "key": "street", "label": "Numéro + Rue", "placeholder": "Numéro et nom de la rue", "required": true, "type": "text" },
      { "key": "postcode", "label": "Code postal", "placeholder": "973xx", "required": true, "type": "text" },
      { "key": "city", "label": "Ville", "placeholder": "ex. Cayenne", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{recipient}}\n{{street}}\n{{postcode}} {{city}}\nFrench Guiana",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Recipient", "placeholder": "Full Name", "required": true, "type": "text" },
      { "key": "street", "label": "Street Number + Street", "placeholder": "Number and street name", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "973xx", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "e.g. Cayenne", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
