      { "key": "state", "label": "Province", "placeholder": "Ashgabat", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "744000", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNNN",
    "regex": "^\\d{6}$",
    "api": "https://www.turkmenpost.gov.tm/",
    "source": "Turkmenpost"
  }
}
