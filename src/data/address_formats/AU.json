    "fields": [
      { "key": "recipient", "label": "Full Name", "placeholder": "John Doe", "required": true, "type": "text" },
      { "key": "street", "label": "Street Address", "placeholder": "123 George St", "required": true, "type": "text" },
      { "key": "city", "label": "Suburb/City", "placeholder": "Sydney", "required": true, "type": "text" },
