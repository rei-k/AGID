{
  "countryCode": "MZ",
  "name": "Mozambique",
  "native": {
    "name": "Moçambique",
    "addressFormat": "{{recipient}}\n{{street}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Nome Completo", "placeholder": "José Eduardo", "required": true, "type": "text" },
      { "key": "street", "label": "Endereço", "placeholder": "Av. 24 de Julho, 123", "required": true, "type": "text" },
      { "key": "postcode", "label": "Código Postal", "placeholder": "1100", "required": false, "type": "text" },
      { "key": "city", "label": "Cidade / Província", "placeholder": "Maputo", "required": true, "type": "text" }
    ]
  },
  "english": {
    "name": "International English",
    "addressFormat": "{{organization}}\n{{street}}\n{{postcode}} {{city}}\nMOZAMBIQUE",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Co./Org.", "placeholder": "" },
      { "key": "street", "label": "Street (Latin)", "placeholder": "Av. 24 de Julho, 123" },
      { "key": "postcode", "label": "Postcode", "placeholder": "1100" },
      { "key": "city", "label": "City", "placeholder": "Maputo" }
    ]
  },
  "international": {
    "pt": {
      "name": "Português (Internacional)",
      "addressFormat": "{{organization}}\n{{street}}\n{{postcode}} {{city}}\nMOÇAMBIQUE",
      "ordering": "small-to-big",
      "fields": [
        { "key": "organization", "label": "Empresa (Latim)", "placeholder": "" },
        { "key": "street", "label": "Endereço (Latim)", "placeholder": "Av. 24 de Julho, 123" },
        { "key": "postcode", "label": "C.P. (Latin)", "placeholder": "1100" },
        { "key": "city", "label": "Cidade", "placeholder": "Maputo" }
      ]
    }
  },
  "postalCode": {
    "format": "NNNN",
    "regex": "^\\d{4}$"
  }
}
