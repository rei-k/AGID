{
  "countryCode": "NZ",
  "name": "New Zealand",
  "native": {
    "name": "English",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{suburb}}\n{{city}} {{postcode}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Building/Company", "placeholder": "" },
      { "key": "houseNumber", "label": "House No.", "placeholder": "123" },
      { "key": "street", "label": "Street", "placeholder": "Queen St" },
      { "key": "suburb", "label": "Suburb", "placeholder": "Auckland Central" },
      { "key": "city", "label": "City", "placeholder": "Auckland" },
      { "key": "postcode", "label": "Postcode", "placeholder": "1010" }
    ]
  },
  "english": {
    "name": "International English",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{suburb}}\n{{city}} {{postcode}}\nNEW ZEALAND",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Co./Org.", "placeholder": "" },
      { "key": "houseNumber", "label": "No.", "placeholder": "123" },
      { "key": "street", "label": "St./Rd. (Latin)", "placeholder": "Queen St" },
      { "key": "suburb", "label": "Suburb", "placeholder": "Auckland Central" },
      { "key": "city", "label": "City", "placeholder": "Auckland" },
      { "key": "postcode", "label": "Postcode", "placeholder": "1010" }
    ]
  },
  "postalCode": {
    "format": "NNNN",
    "regex": "^\\d{4}$"
  }
}
