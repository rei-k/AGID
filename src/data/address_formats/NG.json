{
  "countryCode": "NG",
  "name": "Nigeria",
  "native": {
    "name": "English",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{district}}\n{{city}} {{postcode}}\n{{state}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company", "placeholder": "" },
      { "key": "houseNumber", "label": "Plot/House No.", "placeholder": "123" },
      { "key": "street", "label": "Street Address", "placeholder": "Victoria Island Way" },
      { "key": "district", "label": "District/Area", "placeholder": "Victoria Island" },
      { "key": "city", "label": "City/Town", "placeholder": "Lagos" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "101241" },
      { "key": "state", "label": "State", "placeholder": "Lagos State" }
    ]
  },
  "english": {
    "name": "International English",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{district}}\n{{city}} {{postcode}}\n{{state}}\nNIGERIA",
    "ordering": "small-to-big",
    "fields": []
  },
  "postalCode": {
    "format": "NNNNNN",
    "regex": "^\\d{6}$"
  }
}
