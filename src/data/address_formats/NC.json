{
  "countryCode": "NC",
  "name": "New Caledonia",
  "native": {
    "name": "Nouvelle-Calédonie",
    "addressFormat": "{{recipient}}\n{{street}}\n{{postcode}} {{city}}\nNouvelle-Calédonie",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Destinataire", "placeholder": "Nom complet", "required": true, "type": "text" },
      { "key": "street", "label": "Numéro + Rue", "placeholder": "Numéro et nom de la rue", "required": true, "type": "text" },
      { "key": "postcode", "label": "Code postal", "placeholder": "988xx", "required": true, "type": "text" },
      { "key": "city", "label": "Ville", "placeholder": "ex. Nouméa", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{recipient}}\n{{street}}\n{{postcode}} {{city}}\nNew Caledonia",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Recipient", "placeholder": "Full Name", "required": true, "type": "text" },
      { "key": "street", "label": "Street Number + Street", "placeholder": "Number and street name", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "988xx", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "e.g. Nouméa", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "988NN",
    "regex": "^988\\d{2}$",
    "api": null,
    "source": "OPT-NC"
  }
