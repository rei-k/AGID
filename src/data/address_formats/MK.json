{
  "countryCode": "MK",
  "name": "North Macedonia",
  "native": {
    "name": "Северна Македонија",
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Претпријатие/Организација", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Улица", "placeholder": "Македонија", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Куќен број", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Поштенски код", "placeholder": "1000", "required": true, "type": "text" },
      { "key": "city", "label": "Град", "placeholder": "Скопје", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company/Organization", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Macedonia St", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "House No.", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "1000", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Skopje", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNN",
    "regex": "^\\d{4}$",
    "api": "https://www.posta.com.mk/pronajdi-postenski-broj/",
    "source": "Makedonska Pošta"
  }
}
