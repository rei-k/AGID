{
  "countryCode": "AT",
  "name": "Austria",
  "native": {
    "name": "Österreich",
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Firma/Organisation", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Straße", "placeholder": "Stephansplatz", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Hausnummer", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postleitzahl", "placeholder": "1010", "required": true, "type": "text" },
      { "key": "city", "label": "Stadt", "placeholder": "Wien", "required": true, "type": "text" }
    ]
  },
  "english": {
    "name": "International English",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{postcode}} {{city}}\nAUSTRIA",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Co./Org.", "placeholder": "" },
      { "key": "houseNumber", "label": "No.", "placeholder": "1" },
      { "key": "street", "label": "Street (Latin)", "placeholder": "Stephansplatz" },
      { "key": "postcode", "label": "Postcode", "placeholder": "1010" },
      { "key": "city", "label": "City", "placeholder": "Vienna" }
    ]
  },
  "international": {
    "de": {
      "name": "Deutsch (International)",
      "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\nÖSTERREICH",
      "ordering": "small-to-big",
      "fields": [
        { "key": "organization", "label": "Firma/Org. (Latein)", "placeholder": "" },
        { "key": "street", "label": "Strasse (Latein)", "placeholder": "Stephansplatz" },
        { "key": "houseNumber", "label": "Nr.", "placeholder": "1" },
        { "key": "postcode", "label": "PLZ", "placeholder": "1010" },
        { "key": "city", "label": "Stadt", "placeholder": "Wien" }
      ]
    }
  },
  "postalCode": {
    "format": "NNNN",
    "regex": "^\\d{4}$",
    "api": "https://www.post.at/s/postleitzahl-suche",
    "source": "Österreichische Post"
  }
