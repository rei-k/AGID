{
  "countryCode": "GH",
  "name": "Ghana",
  "native": {
    "name": "English",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{district}}\n{{city}}\n{{postcode}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company", "placeholder": "" },
      { "key": "houseNumber", "label": "Digital Address/No.", "placeholder": "GA-123-4567" },
      { "key": "street", "label": "Street Name", "placeholder": "Independence Ave" },
      { "key": "district", "label": "District", "placeholder": "Osu" },
      { "key": "city", "label": "City/Town", "placeholder": "Accra" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "GA123" }
    ]
  },
  "english": {
    "name": "International English",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{district}}\n{{city}}\n{{postcode}}\nGHANA",
    "ordering": "small-to-big",
    "fields": []
  },
  "postalCode": {
    "format": "AA NNN",
    "regex": "^[A-Z]{2}\\d{3,5}$"
  }
}
