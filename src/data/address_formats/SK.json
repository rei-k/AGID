{
  "countryCode": "SK",
  "name": "Slovakia",
  "native": {
    "name": "Slovensko",
    "addressFormat": "{{street}} {{houseNumber}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Firma/Organizácia", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Ulica", "placeholder": "Obchodná", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Súpisné/orientačné číslo", "placeholder": "1/2", "required": true, "type": "text" },
      { "key": "city", "label": "Mesto", "placeholder": "Bratislava", "required": true, "type": "text" },
      { "key": "postcode", "label": "PSČ", "placeholder": "811 06", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company/Organization", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Obchodna St", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "House/Apt No.", "placeholder": "1/2", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Bratislava", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "811 06", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNN NN",
    "regex": "^\\d{3}\\s?\\d{2}$",
    "api": "https://psc.posta.sk/",
    "source": "Slovenská pošta"
  }
}
