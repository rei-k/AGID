{
  "countryCode": "LI",
  "name": "Liechtenstein",
  "native": {
    "name": "Liechtenstein",
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Firma/Organisation", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Strasse", "placeholder": "Städtle", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Hausnummer", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postleitzahl", "placeholder": "9490", "required": true, "type": "text" },
      { "key": "city", "label": "Ort", "placeholder": "Vaduz", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{postcode}} {{city}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company/Organization", "placeholder": "", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "House No.", "placeholder": "1", "required": true, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Staedtle", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "9490", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Vaduz", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNN",
    "regex": "^\\d{4}$",
    "api": "https://www.post.li/plz-suche",
    "source": "Liechtensteinische Post"
  }
}
