      { "key": "city", "label": "City", "placeholder": "Amman", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "11118", "required": false, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNN",
    "regex": "^\\d{5}$",
    "api": "https://jordanpost.com.jo/en/post-code-search/",
    "source": "Jordan Post"
  }
