      { "key": "street", "label": "الشارع", "placeholder": "شارع الرينبو", "required": true, "type": "text" },
      { "key": "suburb", "label": "المنطقة/الحي", "placeholder": "جبل عمان", "required": true, "type": "text" },
      { "key": "city", "label": "المدينة", "placeholder": "عمان", "required": true, "type": "text" },
      { "key": "postcode", "label": "الرمز البريدي", "placeholder": "11118", "required": false, "type": "text" }
