{
  "countryCode": "DZ",
  "name": "Algeria",
  "native": {
    "name": "الجزائر",
    "addressFormat": "{{recipient}}\n{{street}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "الاسم الكامل", "placeholder": "أحمد بن علي", "required": true, "type": "text" },
      { "key": "street", "label": "العنوان", "placeholder": "١٢ شارع ديدوش مراد", "required": true, "type": "text" },
      { "key": "postcode", "label": "الرمز البريدي", "placeholder": "١٦٠٠٠", "required": true, "type": "text" },
      { "key": "city", "label": "المدينة / الولاية", "placeholder": "الجزائر", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{recipient}}\n{{street}}\n{{postcode}} {{city}}\nAlgeria",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Full Name", "placeholder": "Ahmed Ben Ali", "required": true, "type": "text" },
      { "key": "street", "label": "Street Address", "placeholder": "12 Rue Didouche Mourad", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "16000", "required": true, "type": "text" },
      { "key": "city", "label": "City / Wilaya", "placeholder": "Algiers", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNN",
    "regex": "^\\d{5}$"
  }
}
