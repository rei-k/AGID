  },
  "english": {
    "addressFormat": "{{houseNumber}} {{street}}\n{{suburb}}\n{{city}} {{postcode}}\n{{state}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Building/Company", "placeholder": "Kingdom Centre", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "Building No.", "placeholder": "1234", "required": true, "type": "text" },
