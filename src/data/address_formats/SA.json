      { "key": "state", "label": "Region", "placeholder": "Riyadh Region", "required": false, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "12211", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNN",
    "regex": "^\\d{5}$",
