      { "key": "city", "label": "المدينة", "placeholder": "الرياض", "required": true, "type": "text" },
      { "key": "state", "label": "المنطقة", "placeholder": "منطقة الرياض", "required": false, "type": "text" },
      { "key": "postcode", "label": "الرمز البريدي", "placeholder": "12211", "required": true, "type": "text" }
