      { "key": "city", "label": "City", "placeholder": "Rome", "required": true, "type": "text" },
      { "key": "state", "label": "Province (Abbr.)", "placeholder": "RM", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNN",
