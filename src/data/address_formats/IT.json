      { "key": "houseNumber", "label": "Numero civico", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "CAP", "placeholder": "00100", "required": true, "type": "text" },
      { "key": "city", "label": "Città", "placeholder": "Roma", "required": true, "type": "text" },
