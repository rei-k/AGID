{
  "countryCode": "NL",
  "name": "Netherlands",
  "native": {
    "name": "Nederland",
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Naam", "placeholder": "Volledige naam", "required": true, "type": "text" },
      { "key": "organization", "label": "Bedrijf/Organisatie", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Straat", "placeholder": "Damrak", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Huisnummer", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postcode", "placeholder": "1012 LG", "required": true, "type": "text" },
      { "key": "city", "label": "Woonplaats", "placeholder": "Amsterdam", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Name", "placeholder": "Full Name", "required": true, "type": "text" },
      { "key": "organization", "label": "Company/Organization", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Damrak", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "House No.", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "1012 LG", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Amsterdam", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNN AA",
    "regex": "^\\d{4}\\s?[A-Z]{2}$",
    "api": "https://www.postnl.nl/postcode-zoeken/",
    "source": "PostNL"
  }
}
