    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Yritys/Organisaatio", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Katu", "placeholder": "Mannerheimintie", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Talon numero", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postinumero", "placeholder": "00100", "required": true, "type": "text" },
      { "key": "city", "label": "Postitoimipaikka", "placeholder": "Helsinki", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company/Organization", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Mannerheimintie", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "House No.", "placeholder": "1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "00100", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Helsinki", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNN",
    "regex": "^\\d{5}$",
