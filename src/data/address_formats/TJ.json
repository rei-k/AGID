{
  "countryCode": "TJ",
  "name": "Tajikistan",
  "native": {
    "name": "Тоҷикистон",
    "addressFormat": "{{postcode}}\n{{state}}, {{city}}\n{{street}}, {{houseNumber}}\n{{organization}}",
    "ordering": "big-to-small",
    "fields": [
      { "key": "postcode", "label": "Индекси почта", "placeholder": "734000", "required": true, "type": "text" },
      { "key": "state", "label": "Вилоят", "placeholder": "Душанбе", "required": true, "type": "text" },
      { "key": "city", "label": "Шаҳр/Ноҳия", "placeholder": "Душанбе", "required": true, "type": "text" },
      { "key": "street", "label": "Кӯча", "placeholder": "хиёбони Рӯдакӣ", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Хона/Ҳуҷра", "placeholder": "1", "required": true, "type": "text" },
      { "key": "organization", "label": "Бино/Идора", "placeholder": "", "required": false, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{city}}, {{state}}\n{{postcode}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Building/Office", "placeholder": "", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "House/Apt No.", "placeholder": "1", "required": true, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Rudaki Ave", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Dushanbe", "required": true, "type": "text" },
      { "key": "state", "label": "Province", "placeholder": "Dushanbe", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "734000", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNNN",
    "regex": "^\\d{6}$",
    "api": "http://www.tajikpost.tj/",
    "source": "Tajik Post"
  }
}
