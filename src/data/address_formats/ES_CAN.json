{
  "countryCode": "ES",
  "name": "Canary Islands",
  "native": {
    "name": "Islas Canarias",
    "addressFormat": "{{recipient}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\n{{state}}\nEspaña",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Nombre", "placeholder": "Nombre completo", "required": true, "type": "text" },
      { "key": "street", "label": "Calle", "placeholder": "Nombre de la calle", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Número", "placeholder": "Nr", "required": true, "type": "text" },
      { "key": "postcode", "label": "Código Postal", "placeholder": "35001", "required": true, "type": "text" },
      { "key": "city", "label": "Localidad", "placeholder": "Las Palmas", "required": true, "type": "text" },
      { "key": "state", "label": "Provincia", "placeholder": "Las Palmas", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{recipient}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\n{{state}}\nSpain",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Name", "placeholder": "Full Name", "required": true, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Street name", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "House No", "placeholder": "No", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "35001", "required": true, "type": "text" },
      { "key": "city", "label": "City/Town", "placeholder": "Las Palmas", "required": true, "type": "text" },
      { "key": "state", "label": "Province", "placeholder": "Las Palmas", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "35NNN",
    "regex": "^(35|38)[0-9]{3}$"
  }
}
