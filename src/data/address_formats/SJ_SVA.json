    "fields": [
      { "key": "recipient", "label": "Navn", "placeholder": "Fullt navn", "required": true, "type": "text" },
      { "key": "street", "label": "Gate/Bygning", "placeholder": "Gatenavn eller bygning", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Husnummer", "placeholder": "Nr", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postnummer", "placeholder": "9170", "required": true, "type": "text" },
      { "key": "city", "label": "Poststed", "placeholder": "Longyearbyen", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{recipient}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\nSvalbard",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Name", "placeholder": "Full Name", "required": true, "type": "text" },
      { "key": "street", "label": "Street / Building", "placeholder": "Street or building name", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "House No", "placeholder": "No", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "9170", "required": true, "type": "text" },
      { "key": "city", "label": "City/Town", "placeholder": "Longyearbyen", "required": true, "type": "text" }
    ]
  },
