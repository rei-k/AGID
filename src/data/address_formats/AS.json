{
  "countryCode": "AS",
  "name": "American Samoa",
  "native": {
    "name": "American Samoa",
    "addressFormat": "{{recipient}}\n{{street}}\n{{city}} {{state}} {{postcode}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Full Name", "placeholder": "John Doe", "required": true, "type": "text" },
      { "key": "street", "label": "Street Address / PO Box", "placeholder": "PO Box 123", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Pago Pago", "required": true, "type": "text" },
      { "key": "state", "label": "State", "placeholder": "AS", "required": true, "type": "text" },
      { "key": "postcode", "label": "ZIP Code", "placeholder": "96799", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{recipient}}\n{{street}}\n{{city}} {{state}} {{postcode}}\nAmerican Samoa",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Name", "placeholder": "Full Name", "required": true, "type": "text" },
      { "key": "street", "label": "Street Address / PO Box", "placeholder": "PO Box 123", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Pago Pago", "required": true, "type": "text" },
      { "key": "state", "label": "State", "placeholder": "AS", "required": true, "type": "text" },
      { "key": "postcode", "label": "ZIP Code", "placeholder": "96799", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "96799",
    "regex": "^96799$"
  }
}
