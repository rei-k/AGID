      { "key": "street", "label": "Tänav", "placeholder": "Viru", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Maja/Korter", "placeholder": "1-1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postiindeks", "placeholder": "10111", "required": true, "type": "text" },
      { "key": "city", "label": "Linn/Asula", "placeholder": "Tallinn", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company/Organization", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Viru St", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "House/Apt No.", "placeholder": "1-1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "10111", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Tallinn", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNN",
