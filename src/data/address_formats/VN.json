{
  "countryCode": "VN",
  "name": "Vietnam",
  "native": {
    "name": "Việt Nam",
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{subdistrict}}, {{district}}\n{{city}}, {{state}} {{postcode}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Tên tòa nhà/Công ty", "placeholder": "Landmark 81", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "Số nhà", "placeholder": "208", "required": true, "type": "text" },
      { "key": "street", "label": "Tên đường", "placeholder": "Nguyễn Hữu Cảnh", "required": true, "type": "text" },
      { "key": "subdistrict", "label": "Phường/Xã", "placeholder": "Phường 22", "required": true, "type": "text" },
      { "key": "district", "label": "Quận/Huyện", "placeholder": "Bình Thạnh", "required": true, "type": "text" },
      { "key": "city", "label": "Thành phố", "placeholder": "Hồ Chí Minh", "required": true, "type": "text" },
      { "key": "state", "label": "Tỉnh", "placeholder": "", "required": false, "type": "text" },
      { "key": "postcode", "label": "Mã bưu chính", "placeholder": "700000", "required": false, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{houseNumber}} {{street}}\n{{subdistrict}}, {{district}}\n{{city}}, {{state}} {{postcode}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Building/Company", "placeholder": "Landmark 81", "required": false, "type": "text" },
      { "key": "houseNumber", "label": "House No.", "placeholder": "208", "required": true, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Nguyen Huu Canh", "required": true, "type": "text" },
      { "key": "subdistrict", "label": "Ward/Commune", "placeholder": "Ward 22", "required": true, "type": "text" },
      { "key": "district", "label": "District", "placeholder": "Binh Thanh", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Ho Chi Minh City", "required": true, "type": "text" },
      { "key": "state", "label": "Province", "placeholder": "", "required": false, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "700000", "required": false, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "NNNNNN",
    "regex": "^\\d{6}$",
    "api": "http://mabuuchinh.vn/",
    "source": "Vietnam Post"
  }
}
