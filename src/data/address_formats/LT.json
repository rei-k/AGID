{
  "countryCode": "LT",
  "name": "Lithuania",
  "native": {
    "name": "Lietuva",
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Įmonė/Organizacija", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Gatvė", "placeholder": "Gedimino pr.", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "Namo/Buto nr.", "placeholder": "1-1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Pašto kodas", "placeholder": "LT-01103", "required": true, "type": "text" },
      { "key": "city", "label": "Miestas", "placeholder": "Vilnius", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{organization}}\n{{street}} {{houseNumber}}\n{{postcode}} {{city}}\n{{country}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "organization", "label": "Company/Organization", "placeholder": "", "required": false, "type": "text" },
      { "key": "street", "label": "Street", "placeholder": "Gedimino Ave", "required": true, "type": "text" },
      { "key": "houseNumber", "label": "House/Apt No.", "placeholder": "1-1", "required": true, "type": "text" },
      { "key": "postcode", "label": "Postal Code", "placeholder": "LT-01103", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Vilnius", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "LT-NNNNN",
    "regex": "^LT-\\d{5}$",
    "api": "https://www.post.lt/pasto-kodu-paieska",
    "source": "Lietuvos paštas"
  }
}
