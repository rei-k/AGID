      { "key": "city", "label": "Ville", "placeholder": "Dakar", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{recipient}}\n{{street}}\n{{postcode}} {{city}}\nSenegal",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Full Name", "placeholder": "Moussa Diop", "required": true, "type": "text" },
      { "key": "street", "label": "Street Address", "placeholder": "12 Dakar St", "required": true, "type": "text" },
