{
  "countryCode": "MP",
  "name": "Northern Mariana Islands",
  "native": {
    "name": "Northern Mariana Islands",
    "addressFormat": "{{recipient}}\n{{street}}\n{{city}} {{state}} {{postcode}}",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Full Name", "placeholder": "John Doe", "required": true, "type": "text" },
      { "key": "street", "label": "Street Address / PO Box", "placeholder": "PO Box 123", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Saipan", "required": true, "type": "text" },
      { "key": "state", "label": "State", "placeholder": "MP", "required": true, "type": "text" },
      { "key": "postcode", "label": "ZIP Code", "placeholder": "96950", "required": true, "type": "text" }
    ]
  },
  "english": {
    "addressFormat": "{{recipient}}\n{{street}}\n{{city}} {{state}} {{postcode}}\nNorthern Mariana Islands",
    "ordering": "small-to-big",
    "fields": [
      { "key": "recipient", "label": "Name", "placeholder": "Full Name", "required": true, "type": "text" },
      { "key": "street", "label": "Street Address / PO Box", "placeholder": "PO Box 123", "required": true, "type": "text" },
      { "key": "city", "label": "City", "placeholder": "Saipan", "required": true, "type": "text" },
      { "key": "state", "label": "State", "placeholder": "MP", "required": true, "type": "text" },
      { "key": "postcode", "label": "ZIP Code", "placeholder": "96950", "required": true, "type": "text" }
    ]
  },
  "postalCode": {
    "format": "96950",
    "regex": "^96950$"
  }
}
