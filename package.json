{
  "name": "geogrid-explorer",
  "description": "Interactive map with dynamic grid overlays, elevation metrics, and marine data integration.",
  "license": "MIT",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:rust-wasm": "rustup target add wasm32-unknown-unknown && cargo build --manifest-path native/agid-core/Cargo.toml --target wasm32-unknown-unknown --release && mkdir -p public/wasm && cp native/agid-core/target/wasm32-unknown-unknown/release/agid_core.wasm public/wasm/agid_core.wasm",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@turf/turf": "^7.3.4",
    "@types/adm-zip": "^0.5.8",
    "@types/file-saver": "^2.0.7",
    "@types/geokdbush": "^1.1.5",
    "@types/kdbush": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.17",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "file-saver": "^2.0.5",
    "geokdbush": "^2.1.0",
    "helmet": "^8.1.0",
    "html5-qrcode": "^2.3.8",
    "kdbush": "^4.0.2",
    "lucide-react": "^0.546.0",
    "maplibre-gl": "^5.22.0",
    "motion": "^12.23.24",
    "ngraph.graph": "^20.1.2",
    "ngraph.path": "^1.6.1",
    "open-location-code": "^1.0.3",
    "opencc-js": "^1.3.1",
    "pinyin-pro": "^3.28.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/maplibre-gl": "^1.14.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
